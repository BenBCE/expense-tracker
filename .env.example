# ---- Telegram ----
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Random string used as Telegram webhook secret token (verifies inbound calls).
# `openssl rand -hex 32` is fine.
TELEGRAM_WEBHOOK_SECRET=

# ---- Anthropic ----
ANTHROPIC_API_KEY=
# Optional override
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Public URL ----
# Public HTTPS base URL where Telegram will POST webhooks (e.g. https://bot.example.com)
PUBLIC_BASE_URL=https://bot.example.com

# ---- Database ----
# Inside docker compose this points at the `db` service.
DATABASE_URL=postgresql+asyncpg://expense:expense@db:5432/expense
POSTGRES_USER=expense
POSTGRES_PASSWORD=expense
POSTGRES_DB=expense

# ---- Hetzner Object Storage (S3-compatible) ----
# Region must match the endpoint location: fsn1 | hel1 | nbg1
S3_ENDPOINT_URL=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_RECEIPTS=receipts-raw
S3_BUCKET_REPORTS=reports

# ---- Runtime ----
LOG_LEVEL=INFO
BATCH_POLL_INTERVAL_SECONDS=60
PRESIGN_TTL_SECONDS=86400
BUNDLE_SIZE_LIMIT_MB=45
